generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==================== FOUNDATION ====================

model DiscordGuild {
  id             Int       @id @default(autoincrement())
  guildId        String    @unique @map("guild_id")
  name           String?
  // Channel mappings
  sortiesChannelId  String? @map("sorties_channel_id")
  almanaxChannelId  String? @map("almanax_channel_id")
  metiersChannelId  String? @map("metiers_channel_id")
  forumChannelId    String? @map("forum_channel_id")
  logChannelId      String? @map("log_channel_id")
  officersChannelId String? @map("officers_channel_id")
  annoncesChannelId String? @map("annonces_channel_id")
  // Role mappings
  adminRoleId    String? @map("admin_role_id")
  officerRoleId  String? @map("officer_role_id")
  veteranRoleId  String? @map("veteran_role_id")
  memberRoleId   String? @map("member_role_id")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("discord_guilds")
}

model DiscordChannel {
  id        Int      @id @default(autoincrement())
  guildId   String   @map("guild_id")
  channelId String   @unique @map("channel_id")
  name      String?
  purpose   String?  // sorties, almanax, metiers, forum, logs, officers, annonces
  createdAt DateTime @default(now()) @map("created_at")

  @@map("discord_channels")
}

model DiscordMember {
  id        Int      @id @default(autoincrement())
  guildId   String   @map("guild_id")
  userId    String   @map("user_id")
  username  String?
  joinedAt  DateTime? @map("joined_at")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([guildId, userId])
  @@map("discord_members")
}

model DiscordRole {
  id       Int      @id @default(autoincrement())
  guildId  String   @map("guild_id")
  roleId   String   @unique @map("role_id")
  name     String?
  purpose  String?  // admin, officer, veteran, member, interest

  @@map("discord_roles")
}

model MemberInterestRole {
  id       Int    @id @default(autoincrement())
  guildId  String @map("guild_id")
  userId   String @map("user_id")
  roleId   String @map("role_id")
  roleName String @map("role_name")

  @@unique([guildId, userId, roleId])
  @@map("member_interest_roles")
}

model DiscordMessageMap {
  id         Int      @id @default(autoincrement())
  guildId    String   @map("guild_id")
  channelId  String   @map("channel_id")
  messageId  String   @unique @map("message_id")
  entityType String   @map("entity_type") // activity, quick_call, reward, craft_request, almanax
  entityId   Int      @map("entity_id")
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([entityType, entityId])
  @@map("discord_messages_map")
}

model FeatureFlag {
  id       Int      @id @default(autoincrement())
  guildId  String   @map("guild_id")
  flag     String
  enabled  Boolean  @default(false)

  @@unique([guildId, flag], map: "guildId_flag")
  @@map("feature_flags")
}

model AuditLog {
  id         Int      @id @default(autoincrement())
  guildId    String   @map("guild_id")
  actorId    String   @map("actor_id")
  action     String
  targetType String?  @map("target_type")
  targetId   String?  @map("target_id")
  details    String?  // JSON string
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([guildId, createdAt])
  @@index([actorId])
  @@index([targetType, targetId])
  @@map("audit_log")
}

model JobRun {
  id         Int      @id @default(autoincrement())
  jobName    String   @map("job_name")
  dedupKey   String   @map("dedup_key")
  status     String   // success, failure
  startedAt  DateTime @map("started_at")
  finishedAt DateTime? @map("finished_at")
  durationMs Int?     @map("duration_ms")
  error      String?
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([jobName, dedupKey])
  @@map("job_runs")
}

model IntegrationFailure {
  id           Int      @id @default(autoincrement())
  integration  String   // dofusdude, almanax
  endpoint     String
  statusCode   Int?     @map("status_code")
  errorMessage String?  @map("error_message")
  createdAt    DateTime @default(now()) @map("created_at")

  @@index([integration, createdAt])
  @@map("integration_failures")
}

// ==================== PLAYER PROFILES (Module A) ====================

model PlayerProfile {
  id              Int       @id @default(autoincrement())
  guildId         String    @map("guild_id")
  userId          String    @map("user_id")
  status          String    @default("pending") // pending, approved, rejected
  characterName   String?   @map("character_name")
  characterClass  String?   @map("character_class")
  characterLevel  Int?      @map("character_level")
  orientation     String?   // pvm, pvp, both
  presentation    String?
  professions200  String?   @map("professions_200") // comma-separated list of level 200 professions
  globalAvailable Boolean   @default(false) @map("global_available") // "Glandeur Dispo" flag
  approvedBy      String?   @map("approved_by")
  approvedAt      DateTime? @map("approved_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  @@unique([guildId, userId])
  @@index([guildId, status])
  @@map("player_profiles")
}

// ==================== ACTIVITIES (Module B) ====================

model Activity {
  id              Int      @id @default(autoincrement())
  guildId         String   @map("guild_id")
  createdBy       String   @map("created_by")
  title           String
  activityType    String   @map("activity_type") // donjon, koli, songe, quete, farm, pvp, perco, autre
  description     String?
  roleSlots       String?  @map("role_slots") // e.g. "2T,2H,4D" — parsed for role-based signup
  scheduledAt     DateTime @map("scheduled_at")
  estimatedDuration Int?   @map("estimated_duration") // minutes
  maxPlayers      Int?     @map("max_players")
  status          String   @default("published") // draft, published, ongoing, closed, cancelled
  messageId       String?  @map("message_id")
  channelId       String?  @map("channel_id")
  eventId         String?  @map("event_id") // Discord scheduled event ID
  closedAt        DateTime? @map("closed_at")
  rewardTitle     String?  @map("reward_title")
  rewardAmount    String?  @map("reward_amount")
  rewardsReleased Boolean  @default(false) @map("rewards_released")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  signups    ActivitySignup[]
  reminders  ActivityReminder[]
  rewards    Reward[]

  @@index([guildId, status])
  @@index([guildId, scheduledAt])
  @@map("activities")
}

model ActivitySignup {
  id         Int      @id @default(autoincrement())
  activityId Int      @map("activity_id")
  userId     String   @map("user_id")
  status     String   // confirmed, maybe, unavailable
  role       String?  // tank, heal, dps, etc
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  activity Activity @relation(fields: [activityId], references: [id], onDelete: Cascade)

  @@unique([activityId, userId])
  @@map("activity_signups")
}

model ActivityReminder {
  id         Int      @id @default(autoincrement())
  activityId Int      @map("activity_id")
  remindAt   DateTime @map("remind_at")
  type       String   // 24h, 1h, 10min
  sent       Boolean  @default(false)
  createdAt  DateTime @default(now()) @map("created_at")

  activity Activity @relation(fields: [activityId], references: [id], onDelete: Cascade)

  @@unique([activityId, type])
  @@index([sent, remindAt])
  @@map("activity_reminders")
}

model ActivityTemplate {
  id             Int      @id @default(autoincrement())
  guildId        String   @map("guild_id")
  createdBy      String   @map("created_by")
  name           String
  activityType   String   @map("activity_type")
  description    String?
  estimatedDuration Int?  @map("estimated_duration")
  maxPlayers     Int?     @map("max_players")
  createdAt      DateTime @default(now()) @map("created_at")

  @@map("activity_templates")
}

model QuickCall {
  id          Int      @id @default(autoincrement())
  guildId     String   @map("guild_id")
  createdBy   String   @map("created_by")
  activityType String  @map("activity_type")
  description String?
  playersNeeded Int    @map("players_needed")
  minLevel    Int?     @map("min_level")
  expiresAt   DateTime @map("expires_at")
  status      String   @default("open") // open, filled, expired, cancelled
  messageId   String?  @map("message_id")
  channelId   String?  @map("channel_id")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  responses QuickCallResponse[]

  @@index([guildId, status])
  @@index([expiresAt, status])
  @@map("quick_calls")
}

model QuickCallResponse {
  id          Int      @id @default(autoincrement())
  quickCallId Int      @map("quick_call_id")
  userId      String   @map("user_id")
  status      String   // partant, lead, pas_ce_soir
  createdAt   DateTime @default(now()) @map("created_at")

  quickCall QuickCall @relation(fields: [quickCallId], references: [id], onDelete: Cascade)

  @@unique([quickCallId, userId])
  @@map("quick_call_responses")
}

// ==================== SEARCH QUEUE (Smart LFG Matching) ====================

model SearchQueue {
  id           Int      @id @default(autoincrement())
  guildId      String   @map("guild_id")
  userId       String   @map("user_id")
  activityType String   @map("activity_type") // donjon, koli, songe, quete, farm, pvp, autre
  minLevel     Int?     @map("min_level")
  message      String?  // optional comment
  expiresAt    DateTime @map("expires_at")
  matched      Boolean  @default(false)
  quickCallId  Int?     @map("quick_call_id") // if matched to a QuickCall
  createdAt    DateTime @default(now()) @map("created_at")

  @@index([guildId, activityType, matched])
  @@index([guildId, expiresAt])
  @@map("search_queue")
}

// ==================== PROFESSIONS (Module E) ====================

model ProfessionProfile {
  id         Int      @id @default(autoincrement())
  guildId    String   @map("guild_id")
  userId     String   @map("user_id")
  profession String   // bijoutier, cordonnier, etc.
  level      Int      @default(1)
  available  Boolean  @default(true)
  note       String?
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@unique([guildId, userId, profession])
  @@index([guildId, profession])
  @@index([guildId, available, level])
  @@map("profession_profiles")
}

model CraftRequest {
  id           Int      @id @default(autoincrement())
  guildId      String   @map("guild_id")
  requesterId  String   @map("requester_id")
  crafterId    String?  @map("crafter_id")
  profession   String
  itemName     String   @map("item_name")
  itemAnkamaId Int?     @map("item_ankama_id")
  itemImageUrl String?  @map("item_image_url")
  quantity     Int      @default(1)
  description  String?
  status       String   @default("open") // open, taken, completed, cancelled
  messageId    String?  @map("message_id")
  channelId    String?  @map("channel_id")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@index([guildId, status])
  @@map("craft_requests")
}

model CrafterAvailability {
  id         Int      @id @default(autoincrement())
  guildId    String   @map("guild_id")
  userId     String   @map("user_id")
  available  Boolean  @default(true)
  until      DateTime?
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@unique([guildId, userId])
  @@map("crafter_availability")
}

// ==================== REWARDS (Module F) ====================

model Reward {
  id          Int      @id @default(autoincrement())
  guildId     String   @map("guild_id")
  createdBy   String   @map("created_by")
  recipientId String   @map("recipient_id")
  title       String
  description String?
  amount      String?  // "500k kamas", "1x Dofus Turquoise", etc.
  reason      String?
  status      String   @default("pending") // pending, claimable, claimed, paid, cancelled, disputed
  messageId   String?  @map("message_id")
  channelId   String?  @map("channel_id")
  activityId  Int?     @map("activity_id")
  claimedAt   DateTime? @map("claimed_at")
  paidAt      DateTime? @map("paid_at")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  activity    Activity? @relation(fields: [activityId], references: [id])
  claims      RewardClaim[]
  ledgerEntries LedgerEntry[]

  @@index([guildId, status])
  @@index([recipientId, status])
  @@map("rewards")
}

model RewardClaim {
  id        Int      @id @default(autoincrement())
  rewardId  Int      @map("reward_id")
  userId    String   @map("user_id")
  action    String   // claim, dispute
  note      String?
  createdAt DateTime @default(now()) @map("created_at")

  reward Reward @relation(fields: [rewardId], references: [id], onDelete: Cascade)

  @@map("reward_claims")
}

model LedgerEntry {
  id          Int      @id @default(autoincrement())
  guildId     String   @map("guild_id")
  rewardId    Int?     @map("reward_id")
  actorId     String   @map("actor_id")
  action      String   // created, claimed, paid, cancelled, disputed, status_change
  fromStatus  String?  @map("from_status")
  toStatus    String?  @map("to_status")
  note        String?
  createdAt   DateTime @default(now()) @map("created_at")

  reward Reward? @relation(fields: [rewardId], references: [id])

  @@index([guildId, createdAt])
  @@map("ledger_entries")
}

// ==================== ALMANAX ALERTS (Feature: personal bonus alerts) ====================

model AlmanaxAlert {
  id        Int      @id @default(autoincrement())
  guildId   String   @map("guild_id")
  userId    String   @map("user_id")
  bonusType String   @map("bonus_type") // bonus type ID from DofusDude API

  createdAt DateTime @default(now()) @map("created_at")

  @@unique([guildId, userId, bonusType])
  @@index([guildId])
  @@map("almanax_alerts")
}

// ==================== DUNGEON PROGRESS (Feature: dungeon tracking) ====================

model DungeonProgress {
  id          Int      @id @default(autoincrement())
  guildId     String   @map("guild_id")
  userId      String   @map("user_id")
  dungeonName String   @map("dungeon_name")
  completedAt DateTime @default(now()) @map("completed_at")

  @@unique([guildId, userId, dungeonName])
  @@index([guildId, dungeonName])
  @@map("dungeon_progress")
}

// ==================== FORUM REQUESTS (Module H) ====================

model ForumRequest {
  id          Int      @id @default(autoincrement())
  guildId     String   @map("guild_id")
  createdBy   String   @map("created_by")
  title       String
  description String
  tag         String   // aide, donjon, craft, koli, songes, recrutement_groupe, question, guilde
  status      String   @default("open") // open, resolved, archived
  threadId    String?  @map("thread_id")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  statusHistory ForumRequestStatusHistory[]

  @@index([guildId, status])
  @@map("forum_requests")
}

model ForumRequestStatusHistory {
  id             Int      @id @default(autoincrement())
  forumRequestId Int      @map("forum_request_id")
  fromStatus     String   @map("from_status")
  toStatus       String   @map("to_status")
  changedBy      String   @map("changed_by")
  createdAt      DateTime @default(now()) @map("created_at")

  forumRequest ForumRequest @relation(fields: [forumRequestId], references: [id], onDelete: Cascade)

  @@map("forum_request_status_history")
}
